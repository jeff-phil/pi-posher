{
  "name": "pi-posher",
  "version": "0.1.5",
  "description": "Pi extension that automatically runs commands (formatters, linters, SAST, file conversions, etc.) after agent writes and edits",
  "type": "module",
  "license": "MIT",
  "author": "jeffphil",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeff-phil/pi-posher.git"
  },
  "homepage": "https://github.com/jeff-phil/pi-posher#readme",
  "bugs": "https://github.com/jeff-phil/pi-posher/issues",
  "keywords": [
    "pi",
    "pi-package",
    "format",
    "lint",
    "code-quality",
    "sast",
    "conversions",
    "poshify"
  ],
  "exports": "./src/index.ts",
  "engines": {
    "node": ">=22.19.0"
  },
  "files": ["assets", "CONTRIBUTING.md", "LICENSE", "README.md", "src"],
  "pi": {
    "extensions": ["src/index.ts"]
  },
  "scripts": {
    "test": "node --test \"test/**/*.test.mjs\"",
    "lint": "eslint src/ test/",
    "format": "prettier --write 'src/**/*' 'test/**/*' '*.md' '*.mjs'",
    "prepublishOnly": "npm test && npm run lint && npx tsc --noEmit"
  },
  "dependencies": {
    "ignore": "^5.3.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "markdownlint-cli": "^0.48.0",
    "node-jq": "^6.3.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  }
}
